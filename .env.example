# ─── Copia este archivo como .env y ajusta los valores ───────────────────────
# cp .env.example .env

# Encoding del CSV fuente (latin-1 para archivos exportados desde Excel en español)
DATA_ENCODING=latin-1

# Mínimo de notas para incluir un editor en el análisis
MIN_NOTAS_POR_EDITOR=12

# Número de clusters KMeans (se puede sobreescribir con --k en CLI)
K_CLUSTERS=4

# Editores a excluir del análisis (separados por coma, sin espacios)
EDITORS_TO_EXCLUDE=miriam.castro
